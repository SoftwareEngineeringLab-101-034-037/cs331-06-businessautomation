# Integrations service runtime configuration

PORT=8086
MONGO_URI=mongodb+srv://<db-user>:<db-password>@<cluster>/<optional-db>?appName=<appName>
MONGO_DB=integrations_service

WORKFLOW_ENGINE_URL=http://localhost:8085
POLL_INTERVAL_SECONDS=60
WORKFLOW_INTEGRATION_KEY=ABC

# OAuth app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8086/auth/google/callback

# Frontend origins allowed to call integrations API from browser
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
