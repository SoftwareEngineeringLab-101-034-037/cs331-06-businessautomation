# MongoDB Atlas Configuration (REQUIRED)
MONGO_URI=mongodb+srv://workflow_user:PASSWORD@cluster0.xxxxx.mongodb.net/workflowdb?retryWrites=true&w=majority

# Clerk JWT Authentication (REQUIRED in production)
# Found in Clerk Dashboard → API Keys → Frontend API URL
CLERK_ISSUER_URL=https://<your-clerk-instance>.clerk.accounts.dev

# Optional bearer token used by the workflow service when calling the auth
# service's protected role endpoints for role-based task assignment/claiming.
AUTH_SERVICE_TOKEN=
