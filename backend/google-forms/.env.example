# Google Forms service runtime configuration

PORT=8086
MONGO_URI=mongodb+srv://<db-user>:<db-password>@<cluster>/<optional-db>?appName=<appName>
MONGO_DB=google_forms_service

WORKFLOW_ENGINE_URL=http://localhost:8085
POLL_INTERVAL_SECONDS=60
WORKFLOW_INTEGRATION_KEY=

# OAuth app (set by platform admin)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8086/auth/google/callback
